{
  "expo": {
    "name": "FacadeLens",
    "slug": "facadelens",
    "version": "1.0.0",
    "scheme": "facadelens",
    "newArchEnabled": true,
    "userInterfaceStyle": "dark",
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-font"
    ],
    "ios": {
      "bundleIdentifier": "com.facadelens.facadelens",
      "infoPlist": {
        "NSCameraUsageDescription": "FacadeLens uses your camera to scan building facades.",
        "NSLocationWhenInUseUsageDescription": "FacadeLens uses your location to record where you scanned a building."
      }
    },
    "android": {
      "package": "com.facadelens.facadelens",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2c03dd3a-c29e-4440-b794-1e7cc023a902"
      }
    },
    "owner": "akivagroener"
  }
}
